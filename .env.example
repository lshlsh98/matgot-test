# ============================================================
# .env.example — AWS 배포용 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   .env 파일을 열어 실제 값으로 채운 후 저장
#   .env는 절대 Git에 커밋하지 마세요! (.gitignore에 추가 필수)
# ============================================================


# ── AWS RDS (MySQL) ───────────────────────────────────────────
# RDS 콘솔 > 데이터베이스 > 엔드포인트 및 포트 에서 확인
DB_HOST=xxxx.xxxxxxxxxxxx.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=matgotdb
DB_USER=admin
DB_PASSWORD=your_rds_password


# ── AWS S3 ────────────────────────────────────────────────────
# IAM 콘솔에서 발급한 액세스 키 (S3 Full Access 권한 필요)
# EC2 IAM Role을 사용하는 경우 ACCESS_KEY/SECRET_KEY를 비워도 됨
AWS_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-northeast-2
S3_BUCKET=matmatgotgot-bucket


# ── JWT ───────────────────────────────────────────────────────
# 충분히 긴 랜덤 문자열 사용 (예: openssl rand -hex 64)
JWT_SECRET=your_very_long_and_random_jwt_secret_key_here
JWT_EXPIRATION=86400000   # 토큰 만료 시간 (ms), 86400000 = 24시간


# ── 이메일 (Gmail SMTP 예시) ──────────────────────────────────
# Gmail 사용 시 "앱 비밀번호" 발급 필요 (계정 2단계 인증 후 설정)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password


# ── 파일 업로드 크기 제한 ─────────────────────────────────────
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=50MB


# ── Google OAuth2 ─────────────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# EC2 퍼블릭 IP 또는 도메인으로 설정
GOOGLE_REDIRECT_URI=http://your_ec2_ip_or_domain/api/login/oauth2/code/google


# ── Naver OAuth / API ─────────────────────────────────────────
# Naver Developers (https://developers.naver.com) 에서 발급
NAVER_CLIENT_ID_K=your_naver_client_id_k
NAVER_SECRET_K=your_naver_secret_k
NAVER_CLIENT_ID=your_naver_client_id
NAVER_SECRET=your_naver_secret


# ── CLOVA OCR (영수증 인식) ───────────────────────────────────
# Naver Cloud Platform > CLOVA OCR 에서 발급
CLOVA_OCR_SECRET_KEY=your_clova_ocr_secret_key
CLOVA_OCR_API_URL=https://xxxx.apigw.ntruss.com/custom/v1/xxxxx/recognize


# ── 프론트엔드 Vite 빌드 환경변수 ────────────────────────────
# VITE_BACKSERVER: 브라우저에서 백엔드 API를 호출할 주소
#   - EC2 IP 직접 사용:  http://13.125.xxx.xxx:8080
#   - 도메인 사용:       https://api.yourdomain.com
#   - Nginx 프록시 사용: (같은 도메인이면 /api 상대 경로도 가능)
VITE_BACKSERVER=http://your_ec2_public_ip:8080
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_NAVER_MAP_KEY=your_naver_map_client_id
